{
  "name": "ai-task-manager",
  "version": "1.0.0",
  "description": "AI Task Manager - 前后端分离的任务管理系统（Go + Vue3）",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && go run ./cmd/server",
    "build": "npm run build --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "cd backend && go build -o bin/server ./cmd/server",
    "start:backend": "cd backend && ./bin/server",
    "install:all": "npm install",
    "clean": "rm -rf node_modules frontend/node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skindhu/AI-TASK-MANAGER"
  },
  "homepage": "https://github.com/skindhu/AI-TASK-MANAGER#readme",
  "bugs": {
    "url": "https://github.com/skindhu/AI-TASK-MANAGER/issues"
  }
}
