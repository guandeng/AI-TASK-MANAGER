# Required
ANTHROPIC_API_KEY=your-api-key-here  # Format: sk-ant-api03-...
GOOGLE_API_KEY=your-google-api-key   # Format: AIza...
PERPLEXITY_API_KEY=pplx-abcde # For research (recommended but optional)

# Optional - AI Model Configuration (defaults shown)
MODEL=claude-3-7-sonnet-20250219     # Primary model: claude-3-7-sonnet-20250219, claude-3-opus-20240229
GEMINI_MODEL=gemini-2.5-flash        # Gemini model: gemini-2.5-flash, gemini-2.0-pro, gemini-1.5-pro
PERPLEXITY_MODEL=llama-3.1-sonar-small-128k-online  # Perplexity model: sonar-pro, llama-3.1-sonar-small-128k-online

# AI Parameters
MAX_TOKENS=8192                      # Maximum tokens for model responses
TEMPERATURE=0.7                      # Temperature for model responses (0.0-1.0)
DEBUG=false                       # Enable debug logging (true/false)
LOG_LEVEL=info                    # Log level (debug, info, warn, error)
DEFAULT_SUBTASKS=3                # Default number of subtasks when expanding
DEFAULT_PRIORITY=medium           # Default priority for generated tasks (high, medium, low)
PROJECT_NAME={{projectName}}      # Project name for tasks.json metadata