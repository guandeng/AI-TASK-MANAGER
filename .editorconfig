# EditorConfig - 跨编辑器统一编码和格式配置
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[*.{js,ts,jsx,tsx,vue}]
indent_size = 2

[*.py]
indent_size = 4
