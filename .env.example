# =====================================================
# AI Provider Configuration (选择AI服务提供商)
# =====================================================
# 可选值: gemini, qwen
# 如果不设置，系统会自动检测：有QWEN_API_KEY则用qwen，否则用gemini
# AI_PROVIDER=qwen

# =====================================================
# 千问 (阿里云Qwen) API 配置
# =====================================================
# 千问API密钥 (从 https://dashscope.console.aliyun.com/ 获取)
QWEN_API_KEY=your_qwen_api_key_here
# 或者使用阿里云的标准环境变量名
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 千问��型选择 (默认: qwen-plus)
# 可选值: qwen-turbo, qwen-plus, qwen-max, qwen-max-longcontext
QWEN_MODEL=qwen-plus

# 千问API基础URL (默认: https://dashscope.aliyuncs.com/compatible-mode/v1)
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# =====================================================
# Google Gemini API 配置 (备选)
# =====================================================
# Google API密钥 (用于Gemini API访问)
# GOOGLE_API_KEY=your_google_api_key_here

# Gemini模型 (默认: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-pro

# Gemini API代理 (可选)
# GEMINI_BASE_URL=

# =====================================================
# Perplexity API 配置 (可选，用于研究支持的子任务生成)
# =====================================================
# PERPLEXITY_API_KEY=your_perplexity_api_key_here
# PERPLEXITY_MODEL=sonar-pro

# =====================================================
# 通用配置
# =====================================================
# 模型响应的最大令牌数 (默认: 8192)
# MAX_TOKENS=8192

# 模型响应的温度 (默认: 0.7)
# TEMPERATURE=0.7

# 调试日志 (默认: false)
# DEBUG=false

# 日志级别 - debug, info, warn, error (默认: info)
# LOG_LEVEL=info

# 子任务默认数量 (默认: 3)
# DEFAULT_SUBTASKS=3

# 任务默认优先级 (默认: medium)
# DEFAULT_PRIORITY=medium

# 项目名称
# PROJECT_NAME=Task Master

# 启用中文翻译 (设置后将生成任务的中文翻译字段)
# USE_CHINESE=true
